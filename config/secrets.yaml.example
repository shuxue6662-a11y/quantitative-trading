# ====================================================================
# 敏感信息配置（示例文件）
# 使用时复制为 secrets.yaml 并填入真实信息
# ⚠️ secrets.yaml 不要提交到 Git！
# ====================================================================

# QQ邮箱配置
email:
  smtp_host: "smtp.qq.com"
  smtp_port: 465
  use_ssl: true
  sender: "hongguang_22@qq.com"
  password: "your_smtp_auth_code"  # QQ邮箱授权码（不是QQ密码！）
  receiver: "hongguang_22@qq.com"

# Tushare Token（可选）
tushare:
  token: "your_tushare_token_here"

# 其他API密钥（可选）
api_keys:
  alphavantage: ""
  newsapi: ""